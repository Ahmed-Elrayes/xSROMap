{
  "name": "xsromap",
  "version": "1.5.2",
  "description": "Silkroad Online interactive map library built on Leaflet",
  "author": "JellyBitz",
  "license": "MIT",
  "type": "module",
  "main": "./dist/xsromap.umd.cjs",
  "module": "./dist/xsromap.js",
  "browser": "./dist/xsromap.js",
  "unpkg": "./dist/xsromap.umd.cjs",
  "jsdelivr": "./dist/xsromap.umd.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/xsromap.js",
      "require": "./dist/xsromap.umd.cjs",
      "browser": "./dist/xsromap.js",
      "default": "./dist/xsromap.js"
    },
    "./style.css": "./dist/style.css",
    "./assets/*": "./dist/assets/*"
  },
  "style": "./dist/style.css",
  "sideEffects": [
    "**/*.css"
  ],
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Ahmed-Elrayes/xSROMap.git"
  },
  "homepage": "https://github.com/Ahmed-Elrayes/xSROMap",
  "bugs": {
    "url": "https://github.com/Ahmed-Elrayes/xSROMap/issues"
  },
  "keywords": [
    "silkroad",
    "silkroad-online",
    "map",
    "minimap",
    "leaflet",
    "game-map"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "echo \"No tests specified\""
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "peerDependencies": {
    "leaflet": "^1.7.0"
  },
  "devDependencies": {
    "leaflet": "^1.9.4",
    "vite": "^5.0.0"
  }
}
